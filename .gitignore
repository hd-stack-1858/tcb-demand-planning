# Credentials — NEVER commit these
.env
.env.dev

# Excel master files — stay local, not needed for the running app
master files/
*.xlsx
*.xls
*.csv

# Keep assets/ (logo etc.) — do NOT ignore images

# Raw data downloads — stay local, data already in DB
blinkit_inventory/
blinkit_reports/
amazon_reports/

# Temp files
*.tmp
C\*.txt

# Runtime logs — generated at run time, not source code
automation/logs/

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/

# Streamlit local config
.streamlit/secrets.toml

# Claude Code local directory — memory, settings, lock files — all local, not committed
.claude/

# Browser sessions — contain auth cookies, never commit
.blinkit_session/
.fc_session/

# Downloaded reports — data stays local, not in source control
fnp_reports/
fc_reports/
