# Credentials — NEVER commit these
.env
.env.dev

# Excel master files — stay local, not needed for the running app
*.xlsx
*.xls
*.csv

# Keep assets/ (logo etc.) — do NOT ignore images

# All downloaded reports and reference files — stay local, data already in DB
data/

# Temp files
*.tmp
C\*.txt

# Runtime logs — generated at run time, not source code
automation/logs/

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/

# Streamlit local config
.streamlit/secrets.toml

# Claude Code local directory — memory, settings, lock files — all local, not committed
.claude/

# Browser sessions — contain auth cookies, never commit
.blinkit_session/
.fc_session/

# Legacy report folders (being migrated to data/) — keep ignoring until fully moved
fnp_reports/
fc_reports/
firstcry_reports/
